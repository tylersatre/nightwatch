{
    "name": "laravel/nightwatch-agent",
    "version": "0.0.0",
    "type": "project",
    "description": "The official Laravel Nightwatch agent.",
    "keywords": ["laravel", "monitoring", "insights"],
    "homepage": "https://nightwatch.laravel.com",
    "license": "AGPL-3.0-or-later",
    "support": {
        "docs": "https://nightwatch.laravel.com/docs",
        "issues": "https://github.com/laravel/nightwatch/issues",
        "source": "https://github.com/laravel/nightwatch"
    },
    "authors": [
        {
            "name": "Taylor Otwell",
            "email": "taylor@laravel.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-zlib": "*",
        "psr/http-message": "^1.1",
        "react/event-loop": "^1.5",
        "react/http": "^1.11",
        "react/promise": "^3.2",
        "react/socket": "^1.16"
    },
    "require-dev": {
        "ext-pcntl": "*",
        "evenement/evenement": "^3.0",
        "laravel/pint": "1.21.0",
        "pestphp/pest": "^3.7.4",
        "pestphp/pest-plugin-arch": "^3.1",
        "phpstan/phpstan": "^2.1.6",
        "phpunit/phpunit": "^11.5.3",
        "react/stream": "^1.4",
        "symfony/process": "^7.2",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "Laravel\\NightwatchAgent\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "ci": [
            "@composer test",
            "@composer lint"
        ],
        "lint": [
            "@php vendor/bin/pint --config=pint.ci.json",
            "@php vendor/bin/pint",
            "@php vendor/bin/phpstan --memory-limit=-1 --verbose"
        ],
        "test": [
            "@php vendor/bin/pest"
        ],
        "build": [
            "box compile",
            "box info:signature build/agent.phar > build/signature.txt"
        ],
        "watch": [
            "npm ci",
            "node watch.js"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "autoloader-suffix": "zUjV6thn8dELeOw6"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
